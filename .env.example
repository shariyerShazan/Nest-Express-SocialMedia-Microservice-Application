# ============================================
# Root Infrastructure Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Shared Secret ---
JWT_SECRET=super_secret_for_all_services_change_this_in_prod

# --- PostgreSQL (Auth & Notification) ---
POSTGRES_USER=facebook_admin
POSTGRES_PASSWORD=strongpassword123
POSTGRES_AUTH_DB=facebook_auth
POSTGRES_NOTIFICATION_DB=facebook_notifications

# --- MongoDB (Post & Chat) ---
MONGO_INITDB_ROOT_USERNAME=mongouser
MONGO_INITDB_ROOT_PASSWORD=mongopassword123

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=rabbit_admin
RABBITMQ_DEFAULT_PASS=rabbit_password
RABBITMQ_URL=amqp://rabbit_admin:rabbit_password@rabbitmq:5672

# --- SMTP (Auth Service - Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
